  <object id="5" name="dependiente" type="tienda" x="32" y="144" width="16" height="16">
   <properties>
    <property name="dialogo" value="¡Hola! Somos el POKéMART de pruebas.|Pronto podrás comprar objetos útiles|para tu viaje por JOHTO.|¡Vuelve en cuanto abramos el mostrador!"/>
   </properties>
  </object>
  <object id="6" name="enfermera" type="cura" x="80" y="32" width="16" height="16">
   <properties>
    <property name="dialogo" value="¡Bienvenido al CENTRO POKéMON de pruebas!|Aquí curamos el estado de tus Pokémon…|¡Cuando esté listo el sistema,|volverás a la aventura como nuevo!"/>
   </properties>
  </object>
  <object id="12" name="npc_entrega_curacion_estados" type="entregas" x="112" y="128" width="16" height="16">
   <properties>
    <property name="dialogo" value="Tengo FULL RESTORE y ANTÍDOTOS de sobra…|Cuando el juego guarde el inventario,|te los daré encantado.|¡Por ahora, ánimo, entrenador!"/>
   </properties>
  </object>
  <object id="13" name="npc_regala_pokeballs" type="entregas" x="176" y="112" width="16" height="16">
   <properties>
    <property name="dialogo" value="¡Toma! Son POKE BALLS de cortesía.|Así no te quedas sin nada si ves|un POKéMON salvaje.|…Cuando el regalo esté en el servidor,|¡serán de verdad!"/>
   </properties>
  </object>
  <object id="14" name="npc_explica" type="expl" x="144" y="256" width="16" height="16">
   <properties>
    <property name="dialogo" value="¡Eh! ¿Primera vez en la sala de pruebas?|Por aquí hay ENTRENADORES que te harán|combates de entrenamiento.|¡Pulsa Z frente a ellos y escucha bien!"/>
   </properties>
  </object>
  <object id="33" name="npc_captura" type="captura" x="160" y="48" width="16" height="16">
   <properties>
    <property name="dialogo" value="¿Quieres practicar la CAPTURA?|Te dejo un salvaje suave…|¡Cuando las BALL funcionen de verdad,|aquí será tu sitio favorito!"/>
   </properties>
  </object>
  <object id="34" name="npc_battle_normal" type="battle" x="208" y="48" width="16" height="16">
   <properties>
    <property name="dialogo" value="¿Un combate de calentamiento?|¡Mi POKéMON y el tuyo,|sin trucos raros!|¡Allá vamos!"/>
   </properties>
  </object>
  <object id="35" name="npc_battle_confuso" type="battle" x="272" y="48" width="16" height="16">
   <properties>
    <property name="dialogo" value="¡Ja, ja! Aquí la cabeza|da vueltas y vueltas…|¡COMBATE con CONFUSIÓN!|¿Seguirás sabiendo qué ataque elegir?"/>
   </properties>
  </object>
  <object id="36" name="npc_battle_dormido" type="battle" x="272" y="288" width="16" height="16">
   <properties>
    <property name="dialogo" value="Shhh… Mi POKéMON iba|tan tranquilo que se ha quedado dormido.|¡Es un combate de prueba|con SUEÑO activado!"/>
   </properties>
  </object>
  <object id="38" name="npc_battle_quemado" type="battle" x="16" y="288" width="16" height="16">
   <properties>
    <property name="dialogo" value="¡Ja, ja! Este rival viene|¡ARDIENDO de verdad!|Aguanta el calor del combate…|¡y no te quemes tú también!"/>
   </properties>
  </object>
  <object id="39" name="npc_battle_veneno" type="battle" x="240" y="144" width="16" height="16">
   <properties>
    <property name="dialogo" value="¿Te da miedo el veneno?|En este combate verás|al rival ENVENENADO desde el principio.|¡Aguanta y demuestra tu temple!"/>
   </properties>
  </object>
  <object id="40" name="npc_battle_paralisis" type="battle" x="272" y="144" width="16" height="16">
   <properties>
    <property name="dialogo" value="¡Un duelo eléctrico!|El rival va PARALIZADO…|¡No bajes la guardia|aunque vaya más lento!"/>
   </properties>
  </object>
  <object id="41" name="npc_battle_congelado" type="battle" x="272" y="192" width="16" height="16">
   <properties>
    <property name="dialogo" value="¡Brrr! Hace un frío que pela.|El rival viene CONGELADO…|¡Descongélalo a golpes|si puedes!"/>
   </properties>
  </object>
