# ────────────────────────────────────────────────────────────────
# Pokémon Bytes — variables de entorno de ejemplo
# Copia este archivo como .env.local (frontend) / application-local.properties (backend)
# ────────────────────────────────────────────────────────────────

# ── BACKEND (pokemon-backend/src/main/resources/application-local.properties) ──
# Sobreescribe los valores de application.properties sin versionar credenciales.
#
# DB_URL=jdbc:mysql://localhost:3306/pokemon_web_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# spring.datasource.username=TU_USUARIO_MYSQL
# spring.datasource.password=TU_PASSWORD_MYSQL
# jwt.secret.key=cambia-esto-por-una-clave-segura-de-al-menos-32-caracteres

# ── FRONTEND (pokemon-frontend/.env.local) ──
# Si el backend no corre en localhost:8081 cambia esta URL.
# VITE_API_BASE_URL=http://localhost:8081
